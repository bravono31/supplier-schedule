// ======================================================
// Prisma schema — supplier-schedule (SQL Server)
// ======================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ── Project ────────────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  oemEvents     OemEvent[]
  supplierTasks SupplierTask[]
  sourceImages  SourceImage[]
}

// ── SourceImage (uploaded Gantt images) ───────────────

model SourceImage {
  id          String    @id @default(uuid())
  projectId   String
  filename    String
  storagePath String
  extractedAt DateTime?
  createdAt   DateTime  @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  oemEvents OemEvent[]
}

// ── OemEvent (baseline events extracted from image) ───

model OemEvent {
  id                   String   @id @default(uuid())
  projectId            String
  name                 String
  /// "event" | "test" | "delivery"
  type                 String
  startDate            DateTime
  endDate              DateTime
  isMilestone          Boolean  @default(false)
  sourceImageId        String?
  extractionConfidence Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceImage SourceImage? @relation(fields: [sourceImageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  links       Link[]       @relation("AnchorEvent")
}

// ── SupplierTask ───────────────────────────────────────

model SupplierTask {
  id           String   @id @default(uuid())
  projectId    String
  name         String
  /// "dev" | "order" | "doc" | "test_prep"
  category     String
  startDate    DateTime
  endDate      DateTime
  /// "not_started" | "in_progress" | "done" | "on_hold"
  status       String   @default("not_started")
  driftWarning Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  incomingLinks Link[]  @relation("DependentTask")
}

// ── Link (dependency / anchor) ─────────────────────────

model Link {
  id             String   @id @default(uuid())
  taskId         String
  /// "event" | "task"
  anchorKind     String
  anchorEventId  String?
  anchorTaskId   String?
  /// "FS" | "SS" | "EE" | "SE"
  dependencyType String
  offsetDays     Int      @default(0)
  isLinked       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task        SupplierTask @relation("DependentTask", fields: [taskId], references: [id], onDelete: Cascade)
  anchorEvent OemEvent?    @relation("AnchorEvent", fields: [anchorEventId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
